# Copy to .env.local for local development.
# Set these as Environment Variables in your Vercel project.

# Password users enter to access the dashboard
SITE_PASSWORD=your-secret-password

# A random secret token (run: openssl rand -hex 32)
# This is stored as a cookie after login — keep it secret
SESSION_TOKEN=replace-with-output-of-openssl-rand-hex-32

# URL of your Render.com API service (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-service-name.onrender.com
